# ─── Database ───
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin_pass
POSTGRES_DB=masters_db
DB_CONTAINER_NAME=uslugi_db
# Для docker-compose: @db:5432, для локальной разработки: @localhost:5435
DATABASE_URL="postgresql://admin:admin_pass@localhost:5435/masters_db?schema=public"

# ─── Security (обязательно сгенерировать перед деплоем!) ───
# openssl rand -base64 32
AUTH_SECRET=""
JWT_SECRET=""
CRON_SECRET=""

# ─── Auth.js v5 ───
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ─── Telegram ───
TELEGRAM_BOT_TOKEN="your_bot_token"
TELEGRAM_BOT_NAME="your_bot_name"
NEXT_PUBLIC_BOT_NAME="your_bot_name"
NEXT_PUBLIC_BOT_ID="123456789"
ADMIN_TELEGRAM_ID=your_id

# ─── App URLs ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Yandex Maps
# Public JS API key. Restrict it by HTTP Referer in Yandex Developer Dashboard.
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""
# Optional server-side Geocoder API key. Prefer a separate key with server-side restrictions.
YANDEX_GEOCODER_API_KEY=""

# ─── Admin (будет захеширован при сидинге) ───
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=change_me_in_production

# ─── Email / SMTP (Phase 2) ───
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ─── Google OAuth (Phase 2) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Socket.io / Chat (Phase 7) ───
REDIS_URL=redis://localhost:6380
SOCKET_PORT=3001

# ─── Шифрование сообщений (64 hex-символа = 32 байта AES-256) ───
# Сгенерировать: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_chars_here_generate_with_openssl_rand_-hex_32
