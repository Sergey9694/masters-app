# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin_pass
POSTGRES_DB=uslugi_db
DB_CONTAINER_NAME=uslugi_db
# Use "db" for docker-compose, "localhost" for local development
DATABASE_URL="postgresql://admin:admin_pass@localhost:5435/uslugi_db?schema=public"

# Auth
JWT_SECRET=your_secret_here
TELEGRAM_BOT_TOKEN=your_bot_token
ADMIN_TELEGRAM_ID=your_id

# --- Admin Settings ---
# Email администратора
ADMIN_EMAIL=admin@test.com
# Пароль администратора (будет автоматически захеширован при сидинге)
ADMIN_PASSWORD=password123
# Альтернатива: можно передать сразу хеш (если задан ADMIN_PASSWORD, хеш игнорируется)
# ADMIN_PASSWORD_HASH=...

# Auth v2 (Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Multi-city (Phase 3)
DEFAULT_CITY=moscow
