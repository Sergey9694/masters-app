# Database
DATABASE_URL="postgresql://admin:admin_pass@localhost:5435/masters_db?schema=public"
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin_pass
POSTGRES_DB=masters_db

# Security
# Generate with: openssl rand -base64 32
# Must be >=32 bytes in production. Dev fallback is used if empty.
JWT_SECRET=""

# Auth.js v5 (обязательно на проде)
# AUTH_SECRET — openssl rand -base64 32
# AUTH_URL    — публичный URL приложения (https://domain.tld)
# AUTH_TRUST_HOST=true — обязательно за reverse-proxy (nginx)
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Telegram
TELEGRAM_BOT_TOKEN="your_bot_token"
TELEGRAM_BOT_NAME="your_bot_name"
# NEXT_PUBLIC_ prefix exposes the value to the client bundle (required for landing link)
NEXT_PUBLIC_BOT_NAME="your_bot_name"
TELEGRAM_BOT_ID="123456789"       # числовой ID бота (часть до : в токене)

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Yandex Maps
# Public JS API key. Restrict it by HTTP Referer in Yandex Developer Dashboard.
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""
# Optional server-side Geocoder API key. Prefer a separate key with server-side restrictions.
YANDEX_GEOCODER_API_KEY=""

# Cron Jobs (for scheduled endpoints like /api/jobs/expire-tasks)
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# ─── Socket.io / Chat (Phase 7) ───
REDIS_URL=redis://localhost:6380
SOCKET_PORT=3001

# ─── Шифрование сообщений (64 hex-символа = 32 байта AES-256) ───
# Сгенерировать: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_chars_here_generate_with_openssl_rand_-hex_32
